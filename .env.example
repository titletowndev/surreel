# --- Client (exposed to the browser; safe public keys only) ---
VITE_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR-ANON-KEY

# --- Server-only (NEVER exposed client-side) ---
# Used by the Cloudflare Pages Function in /functions/api/tmdb and by the Vite dev proxy.
# This is a TMDB v3 API key. A v4 read access token also works (see functions/api/tmdb/[[path]].ts).
TMDB_API_KEY=YOUR-TMDB-V3-API-KEY
